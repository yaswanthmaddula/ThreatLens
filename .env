# URLShield Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key

# Model paths (relative to backend/ directory)
MODEL_PATH=url_model.pkl
DATASET_PATH=../dataset/phishing_urls.csv
METRICS_PATH=model_metrics.json

# CORS — set to your frontend URL in production
# Example: ALLOWED_ORIGINS=https://urlshield.vercel.app
ALLOWED_ORIGINS=*

# Rate limiting (Flask-Limiter format)
RATE_LIMIT_DEFAULT=200 per day
RATE_LIMIT_PREDICT=60 per minute

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server port
PORT=5000
